@model ResetPasswordViewModel

<div class="min-h-screen flex items-center justify-center bg-base-200 px-4 py-12 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8">
        <!-- Card Container -->
        <div class="bg-base-100 border border-base-300 rounded-2xl shadow-xl p-6 sm:p-8">
            <div class="mb-6 text-center">
                <h3 class="text-xl font-bold text-base-content">Definir Nova Palavra-passe</h3>
                <p class="text-xs text-base-content/50 mt-1">Preencha os campos abaixo para concluir a alteração</p>
            </div>

            <!-- Form container for HTMX swaps -->
            <div id="reset-password-container" class="w-full">
                <partial-error-safe name="_ResetPasswordForm" model="Model" />
            </div>
        </div>
    </div>
</div>
