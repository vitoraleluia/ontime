@model ForgotPasswordViewModel

<div class="min-h-screen flex items-center justify-center bg-base-200 px-4 py-12 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8">
        <!-- Card Container -->
        <div class="bg-base-100 border border-base-300 rounded-2xl shadow-xl p-6 sm:p-8">
            <div class="mb-6 text-center">
                <h3 class="text-xl font-bold text-base-content">Recuperar Palavra-passe</h3>
                <p class="text-xs text-base-content/50 mt-1">Introduza o seu e-mail para receber um link de recuperação</p>
            </div>

            <!-- Form container for HTMX swaps -->
            <div id="forgot-password-container" class="w-full">
                <partial-error-safe name="_ForgotPasswordForm" model="Model" />
            </div>
            
            <div class="mt-6 text-center text-sm">
                <a href="/Auth/Login" class="font-semibold text-primary hover:underline transition-all duration-200">
                    Voltar para Login
                </a>
            </div>
        </div>
    </div>
</div>
