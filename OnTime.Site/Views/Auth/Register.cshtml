@model RegisterViewModel

<div class="min-h-screen flex items-center justify-center bg-base-200 px-4 py-12 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8">
        <!-- Card Container -->
        <div class="bg-base-100 border border-base-300 rounded-2xl shadow-xl p-6 sm:p-8">
            <div class="mb-6 text-center">
                <h3 class="text-xl font-bold text-base-content">Criar nova conta</h3>
                <p class="text-xs text-base-content/50 mt-1">Escolha o seu método de registo preferido</p>
            </div>

            <!-- 1. Google Login (First Choice) -->
            <partial-error-safe name="_GoogleButton" model='"Registar com o Google"' />

            <!-- Divider -->
            <div class="divider text-xs text-base-content/40 uppercase tracking-wider mb-6">ou</div>

            <!-- 2. Email/Password/Other Fields Form -->
            <div id="register-form-container" class="w-full">
                <partial-error-safe name="_RegistrationForm" model="Model"/>
            </div>

            <!-- Login Redirect Link -->
            <div class="mt-6 pt-6 border-t border-base-200 text-center">
                <p class="text-sm text-base-content/60">
                    Já tem uma conta? 
                    <a href="/Auth/Login" class="font-semibold text-primary hover:underline transition-all duration-200">
                        Iniciar sessão
                    </a>
                </p>
            </div>
        </div>
    </div>
</div>

@section BottomScripts {
    <script src="~/vendor/aspnet-validation.min.js" asp-append-version="true"></script>
    <script>
        function initializeValidation() {
            var v = new aspnetValidation.ValidationService();
            v.bootstrap();
        }

        document.addEventListener("DOMContentLoaded", function () {
            initializeValidation();
            
            // Re-bind validation after HTMX dynamic swaps
            document.body.addEventListener("htmx:afterSwap", function (evt) {
                if (evt.detail.target.id === "register-form-container") {
                    initializeValidation();
                }
            });
        });
    </script>
}
