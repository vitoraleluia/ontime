@model LoginViewModel
@{
    ViewData["Title"] = "Entrar - On Time";
}

<div class="min-h-screen flex items-center justify-center bg-base-200 px-4 py-12 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8">
        <!-- Logo and Header -->
        <div class="text-center">
            <div class="inline-flex items-center justify-center p-3 rounded-2xl bg-primary/10 text-primary mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24"
                     stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
            <h2 class="text-4xl font-extrabold tracking-tight text-base-content">
                On Time
            </h2>
            <p class="mt-2 text-sm text-base-content/60">
                A sua plataforma moderna de agendamentos
            </p>
        </div>

        <!-- Card Container -->
        <div class="bg-base-100 border border-base-300 rounded-2xl shadow-xl p-6 sm:p-8">
            <div class="mb-6 text-center">
                <h3 class="text-xl font-bold text-base-content">Iniciar Sessão</h3>
                <p class="text-xs text-base-content/50 mt-1">Escolha o seu método de autenticação preferido</p>
            </div>

            <!-- 1. Google Login (First Choice) -->
            <partial-error-safe name="_GoogleButton" model='"Entrar com o Google"'/>

            <!-- Divider -->
            <div class="divider text-xs text-base-content/40 uppercase tracking-wider mb-6">ou com e-mail</div>

            <!-- 2. Email/Password Form -->
            <div id="login-form-container" class="w-full">
                <partial-error-safe name="_LoginForm" model="Model"/>
            </div>

            <!-- Register Redirect Link -->
            <div class="mt-6 pt-6 border-t border-base-200 text-center">
                <p class="text-sm text-base-content/60">
                    Ainda não tem conta?
                    <a href="/Auth/Register"
                       class="font-semibold text-primary hover:underline transition-all duration-200">
                        Registe-se aqui
                    </a>
                </p>
            </div>
        </div>
    </div>
</div>

@section BottomScripts {
    <script src="~/vendor/aspnet-validation.min.js" asp-append-version="true"></script>
    <script>
        function initializeValidation() {
            var v = new aspnetValidation.ValidationService();
            v.bootstrap();
        }

        document.addEventListener("DOMContentLoaded", function () {
            initializeValidation();

            // Re-bind validation after HTMX dynamic swaps
            document.body.addEventListener("htmx:afterSwap", function (evt) {
                if (evt.detail.target.id === "login-form-container") {
                    initializeValidation();
                }
            });
        });
    </script>
}